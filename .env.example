# STEP & RIDE — 環境変数

# AI収集パイプライン（pipeline/）。未設定なら collect は DRY-RUN で動く。
# Mac mini の週1バッチ実行時に設定する。サーバーサイドのみ・フロントに露出させない。
ANTHROPIC_API_KEY=

# Supabase（Googleログイン・アカウント同期）。未設定の間はログインUIが「近日公開」表示になる。
# anon キーは公開前提（保護は supabase/schema_auth.sql の RLS が担う）。
# service_role キーは絶対にここへ書かない・クライアントに渡さないこと。
# ローカルは .env.local、 本番は Vercel の Environment Variables に設定する。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
